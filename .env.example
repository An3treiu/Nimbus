# Copy to .env and fill in. Used by docker-compose.yml.

# Public domain pointed at this VPS (Caddy gets HTTPS for it automatically).
NIMBUS_DOMAIN=drive.example.com

# The GitHub repo used as the drive.
NIMBUS_DRIVE_OWNER=your-username
NIMBUS_DRIVE_REPO=your-drive-repo
NIMBUS_DRIVE_BRANCH=main

# REQUIRED for public deployment: a long random string. Send it as
# `Authorization: Bearer <token>` (the web UI prompts for it once).
#   generate: openssl rand -hex 32
NIMBUS_ADMIN_TOKEN=

# Auth to GitHub: either a PAT with `repo` scope, or an OAuth App client id
# (then click "Connect GitHub" in the UI). At least one is needed.
NIMBUS_GITHUB_TOKEN=
NIMBUS_GITHUB_CLIENT_ID=

# Optional: enable client-side encryption (recommended).
NIMBUS_ENCRYPTION_PASSPHRASE=

# Optional: AI for semantic search + chat. openai | ollama | anthropic.
NIMBUS_AI_PROVIDER=
NIMBUS_AI_API_KEY=
NIMBUS_AI_MODEL=
NIMBUS_AI_CHAT_MODEL=
